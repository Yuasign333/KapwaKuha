<Application x:Class="KapwaKuha.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="View/ChooseRoleWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Brand colors -->
        <SolidColorBrush x:Key="BrandTeal"      Color="#00B4D8"/>
        <SolidColorBrush x:Key="BrandTealDark"  Color="#0077B6"/>
        <SolidColorBrush x:Key="BrandTealLight" Color="#90E0EF"/>
        <SolidColorBrush x:Key="BrandNavy"      Color="#03045E"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#5E7A8A"/>
        <SolidColorBrush x:Key="TextHint"       Color="#AAAAAA"/>
        <SolidColorBrush x:Key="ColorError"     Color="#C0304A"/>
        <SolidColorBrush x:Key="ColorErrorBg"   Color="#FFF0F5"/>
        <SolidColorBrush x:Key="SurfaceInput"   Color="#F0F8FB"/>
    </Application.Resources>
</Application>