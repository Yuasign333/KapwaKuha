<Window x:Class="KapwaKuha.View.ActiveListingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Active Listings"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.10" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Active Listings" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Command="{Binding RefreshCommand}"
            Content="⟳" Background="Transparent" BorderThickness="0"
            Foreground="#CAF0F8" FontSize="16" Cursor="Hand"
            VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Command="{Binding EditPostCommand}"
            IsEnabled="{Binding CanEditSelected}"
            Background="Transparent" BorderThickness="0"
            Foreground="#90E0EF" FontSize="12" Cursor="Hand"
            VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="✏ Edit"/>
                        </Button>
                        <Button Command="{Binding DeleteItemCommand}"
            IsEnabled="{Binding IsItemSelected}"
            Background="Transparent" BorderThickness="0"
            Foreground="#FF8A80" FontSize="12" Cursor="Hand"
            VerticalAlignment="Center">
                            <TextBlock Text="🗑 Delete"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main: DataGrid -->
           <Border Grid.Row="1" Margin="20,16" CornerRadius="22" Padding="24" BorderThickness="1.5">
    
    <Border.BorderBrush>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="White" Offset="0"/>
            <GradientStop Color="#33FFFFFF" Offset="1"/>
        </LinearGradientBrush>
    </Border.BorderBrush>

    <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#CCFFFFFF" Offset="0"/>
            <GradientStop Color="#66FFFFFF" Offset="1"/>
        </LinearGradientBrush>
    </Border.Background>

    <Border.Effect>
        <DropShadowEffect Color="#0077B6" BlurRadius="40" ShadowDepth="2" Opacity="0.2"/>
    </Border.Effect>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📋 My Posted Items" FontSize="20" FontWeight="Bold" Foreground="#03045E"/>
            <TextBlock Text="All items you have donated. Select an item then click Delete to remove Available items."
                       FontSize="12" Foreground="#5E7A8A" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  HorizontalContentAlignment="Stretch">
            
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3300B4D8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="12" BorderBrush="#B390E0EF" BorderThickness="1.2" 
                            Background="#4DFFFFFF" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/> <ColumnDefinition Width="1.5*"/> <ColumnDefinition Width="120"/> <ColumnDefinition Width="100"/> </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Item_Name}" FontSize="15" FontWeight="Bold" Foreground="#03045E" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Item_ID, StringFormat='ID: {0}'}" FontSize="11" Foreground="#5E7A8A" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="{Binding Category_Name}" FontSize="13" FontWeight="SemiBold" Foreground="#0077B6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Item_Condition}" FontSize="11" Foreground="#5E7A8A"/>
                                    <TextBlock Text=" • " FontSize="11" Foreground="#90E0EF"/>
                                    <TextBlock Text="{Binding PostType}" FontSize="11" Foreground="#5E7A8A"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="2" CornerRadius="10" Padding="12,6" 
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{Binding StatusBadgeBackground}">
                                <TextBlock Text="{Binding Item_Status}" FontSize="11" FontWeight="Bold" 
                                           Foreground="{Binding StatusBadgeColor}" HorizontalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="Posted" FontSize="10" Foreground="#5E7A8A" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding StorageDaysDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#03045E" HorizontalAlignment="Right"/>
                            </StackPanel>
                            
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Border>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#03045E" Padding="20,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#90E0EF" FontSize="11" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>