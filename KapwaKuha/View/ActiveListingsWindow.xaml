<Window x:Class="KapwaKuha.View.ActiveListingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Active Listings"
        Height="620" Width="1000"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Active Listings" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Command="{Binding RefreshCommand}"
                                Content="⟳" Background="Transparent" BorderThickness="0"
                                Foreground="#CAF0F8" FontSize="16" Cursor="Hand"
                                VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Command="{Binding DeleteItemCommand}"
                                IsEnabled="{Binding IsItemSelected}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#FF8A80" FontSize="12" Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="🗑 Delete"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main: DataGrid -->
            <Border Grid.Row="1" Background="White" CornerRadius="16" Margin="20,16">
                <Border.Effect>
                    <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,16,20,10">
                        <TextBlock Text="📋 My Posted Items" FontSize="16" FontWeight="Bold"
                                   Foreground="#03045E"/>
                        <TextBlock Text="All items you have donated. Select a row then click Delete to remove Available items."
                                   FontSize="11" Foreground="#5E7A8A" Margin="0,3,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" CanUserResizeRows="False"
                              SelectionMode="Single" Background="Transparent"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EBF7FB"
                              RowBackground="White" AlternatingRowBackground="#F7FBFD"
                              ColumnHeaderHeight="38" RowHeight="48" FontSize="13"
                              Margin="0,0,0,8">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#EBF7FB"/>
                                <Setter Property="Foreground" Value="#0077B6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="14,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item ID" Binding="{Binding Item_ID}"
                                                Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Item Name" Binding="{Binding Item_Name}"
                                                Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category_Name}"
                                                Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Condition" Binding="{Binding Item_Condition}"
                                                Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding PostType}"
                                                Width="110" IsReadOnly="True"/>
                            <!-- Status badge -->
                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="10,4"
                                                HorizontalAlignment="Left" Margin="4,0"
                                                Background="{Binding StatusBadgeBackground}">
                                            <TextBlock Text="{Binding Item_Status}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding StatusBadgeColor}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Posted" Binding="{Binding StorageDaysDisplay}"
                                                Width="130" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Foreground" Value="#5E7A8A"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#03045E" Padding="20,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#90E0EF" FontSize="11" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>