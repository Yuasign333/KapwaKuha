<Window x:Class="KapwaKuha.View.AdminRejectReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejection Reason"
        Height="390" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        FontFamily="Segoe UI"
        ShowInTaskbar="False"
        Background="#F3F4F6">

    <Border Background="White" CornerRadius="0">
        <Grid>
            <Border Height="6" VerticalAlignment="Top">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0A2540" Offset="0"/>
                        <GradientStop Color="#0077B6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="28,32,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="TitleLabel"
                           FontSize="18" FontWeight="SemiBold" Foreground="#0A2540"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" x:Name="SubtitleLabel"
                           FontSize="13" Foreground="#6B7280"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <Border Grid.Row="2" CornerRadius="6" BorderBrush="#D1D5DB"
                        BorderThickness="1" Background="#F9FAFB" Padding="12,10">
                    <TextBox x:Name="ReasonBox"
                             Background="Transparent" BorderThickness="0"
                             FontSize="14" Foreground="#111827" TextWrapping="Wrap"
                             AcceptsReturn="True" Height="70"
                             VerticalScrollBarVisibility="Auto"
                             Text="Please revise your post and resubmit."
                             VerticalContentAlignment="Top"/>
                </Border>

                <StackPanel Grid.Row="4" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,20,0,0">

                    <Button x:Name="CancelBtn" Content="Cancel"
                            Width="90" Height="36" Margin="0,0,12,0"
                            Foreground="#374151" FontWeight="Medium" FontSize="13"
                            Background="#FFFFFF" BorderThickness="1"
                            BorderBrush="#D1D5DB" Cursor="Hand"
                            Click="CancelBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="6"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F3F4F6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="ConfirmBtn" Content="Confirm Rejection"
                            Height="36" Padding="16,0"
                            Foreground="White" FontWeight="SemiBold" FontSize="13"
                            BorderThickness="0" Cursor="Hand"
                            Click="ConfirmBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" CornerRadius="6" Padding="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#EF4444" Offset="0"/>
                                            <GradientStop Color="#DC2626" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Margin="16,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#B91C1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>