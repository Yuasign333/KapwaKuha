<Window x:Class="KapwaKuha.View.AdminSupportChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Admin Support"
        Height="780" Width="1100"
WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0F8FF" Offset="0"/>
                <GradientStop Color="#E8F4FD" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TOPBAR ══ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0A2540" Offset="0"/>
                    <GradientStop Color="#0077B6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#0A2540" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back button -->
                <Button Grid.Column="0" x:Name="BackBtn" Click="BackBtn_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="White" FontSize="13" Cursor="Hand"
                        VerticalAlignment="Center" Padding="8,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="←" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Back" Margin=" 0,2,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Complainant profile centre -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Avatar -->
                    <Grid Width="44" Height="44" Margin="0,0,12,0">
                        <Ellipse Fill="#CAF0F8"/>
                        <TextBlock x:Name="AvatarEmoji" Text="👤" FontSize="22"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse x:Name="AvatarEllipse" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TopBarTitle" Text="KapwaKuha Support"
                                       FontSize="15" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center"/>
                            <!-- Role chip — shown in admin mode -->
                            <Border x:Name="RoleChip" CornerRadius="10" Padding="8,2"
                                    Margin="10,0,0,0" VerticalAlignment="Center"
                                    Background="#CAF0F8" Visibility="Collapsed">
                                <TextBlock x:Name="RoleChipText" FontSize="10" FontWeight="Bold"
                                           Foreground="#0A2540"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="TopBarSubtitle" Text="Official support channel"
                                   FontSize="10" Foreground="#CAF0F8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Admin badge -->
                <Border Grid.Column="2" CornerRadius="8" Padding="10,4"
                        Background="#0A2540" VerticalAlignment="Center">
                    <TextBlock Text="🛡 Admin View" FontSize="11" FontWeight="Bold"
                               Foreground="#CAF0F8" x:Name="AdminBadge" Visibility="Collapsed"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ CHAT BODY ══ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- Typing indicator -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" x:Name="ScrollView"
                          VerticalScrollBarVisibility="Auto" Padding="20,12">
                <ItemsControl x:Name="MessagesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="{Binding SenderLabel}" FontSize="10"
                                           FontWeight="SemiBold" Margin="4,0,4,2" Opacity="0.6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#0077B6"/>
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Foreground" Value="#6B7280"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Border MaxWidth="460" Padding="12,10" CornerRadius="16"
                                        HorizontalAlignment="{Binding HAlignment}" Margin="0,0,0,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                    <Setter Property="Background" Value="#0077B6"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#0A2540"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding TimeLabel}" FontSize="10"
                                                   Opacity="0.6" HorizontalAlignment="Right" Margin="0,4,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#6B7280"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFromUser}" Value="True">
                                                            <Setter Property="Foreground" Value="#CAF0F8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Typing indicator -->
            <Border Grid.Row="1" x:Name="TypingIndicator" Visibility="Collapsed"
                    Padding="20,6">
                <StackPanel Orientation="Horizontal">
                    <Border Background="White" CornerRadius="12" Padding="12,8"
                            BorderBrush="#E5E7EB" BorderThickness="1">
                        <TextBlock Text="KapwaKuha Support is typing…" FontSize="12"
                                   Foreground="#6B7280" FontStyle="Italic"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Input bar -->
            <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="0,1,0,0" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="24" BorderBrush="#D1D5DB"
                            BorderThickness="1" Background="#F9FAFB" Padding="16,0" Margin="0,0,10,0">
                        <TextBox x:Name="InputBox" Background="Transparent"
                                 BorderThickness="0" FontSize="13"
                                 VerticalContentAlignment="Center" Height="40"
                                 KeyDown="InputBox_KeyDown"/>
                    </Border>
                    <Button Grid.Column="1" x:Name="SendBtn"
                            Width="44" Height="44" BorderThickness="0"
                            Cursor="Hand" Click="SendBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="22">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00B4D8" Offset="0"/>
                                            <GradientStop Color="#0077B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="➤" FontSize="16" Foreground="White"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>