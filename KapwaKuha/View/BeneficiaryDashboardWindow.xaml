<Window x:Class="KapwaKuha.View.BeneficiaryDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:BeneficiaryDashboardDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Beneficiary Dashboard"
        Height="640" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" ResizeMode="CanResize">
    <Grid>

        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
      
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.05" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />



        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>



            <!-- ANIMATED SIDEBAR -->
            <Border Grid.Column="0" Width="220" Style="{StaticResource AnimatedSidebarStyle}"
        BorderThickness="0,0,1.5,0">

                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#4D0077B6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,24,20,16">

                        <StackPanel Orientation="Horizontal">

                            <Grid Width="38" Height="38" Margin="0,0,4,0">

                                <Image Source="https://i.imgur.com/FHFRQxB.png" 
                   Width="60" Height="60" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
            <Run Foreground="#FF03045E" Text="Kapwa"/><Run Foreground="#FF00B4D8" Text="Kuha"/>
                            </TextBlock>

                        </StackPanel>

                        <TextBlock Text="Beneficiary Portal" FontSize="11" FontWeight="SemiBold" Foreground="#0077B6" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding UserLabel}" FontSize="11" Foreground="#5E7A8A" Margin="0,4,0,0"/>

                        <Rectangle Height="1.2" Margin="0,16,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#330077B6" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="12,0">

                        <Button Command="{Binding ClaimTrackerCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Claim Tracker" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding BrowseItemsCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛍️" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Browse Items" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding NeedsWishlistCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Needs Wishlist" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <Button Command="{Binding ChatCommand}" Style="{StaticResource CardHoverBtn}" Padding="0" Margin="0,4">
                            <Border CornerRadius="12" Padding="12,12" Style="{StaticResource SidebarItemStyle}" Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬" Margin="0,0,12,0" FontSize="14"/>
                                    <TextBlock Text="Messages" Foreground="#03045E" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="12,0,12,24">

                        <Rectangle Height="1.2" Margin="8,0,8,16">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A0077B6" Offset="0"/>
                                    <GradientStop Color="#330077B6" Offset="0.5"/>
                                    <GradientStop Color="#1A0077B6" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <Button Command="{Binding LogoutCommand}" Style="{StaticResource CardHoverBtn}" Padding="0">
                            <Border CornerRadius="12" Padding="12,12" Background="#1AC0304A">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬅" Margin="0,0,12,0" Foreground="#C0304A" FontSize="14"/>
                                    <TextBlock Text="Log Out" Foreground="#C0304A" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>


            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#AAFFFFFF">
                    <Border.Effect>
                        <DropShadowEffect Color="#0077B6" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>

                    <Grid Margin="16,0">
                        <Button Command="{Binding MyBAccountCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent" 
                    BorderThickness="0"
                    Cursor="Hand" 
                    Padding="0">

                            <Border CornerRadius="16" 
                        Padding="12,6" 
                        Background="#4DFFFFFF" 
                        BorderBrush="#B390E0EF" 
                        BorderThickness="1">

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👤" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>

                                    <TextBlock Text="{Binding UserLabel}" 
                                   FontSize="11"
                                   Foreground="#03045E" 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28">
                    <StackPanel>


                        <TextBlock Text="How can we help you today?"
                                   FontSize="20" FontWeight="Bold" Foreground="#03045E" Margin="0,0,0,6"/>
                        <TextBlock Text="Browse items, track your claims, or post your organization's needs."
                                   FontSize="12" Foreground="#5E7A8A" Margin="0,0,0,24"/>
                        <UniformGrid Rows="2" Columns="2">
                            <Button Command="{Binding ClaimTrackerCommand}" Style="{StaticResource CardHoverBtn}" Margin="0,0,14,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="📦" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Claim Tracker" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Track your received donations" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding BrowseItemsCommand}" Style="{StaticResource CardHoverBtn}" Margin="0,0,0,14">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="🛍️" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Browse Items" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Explore available donations" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding NeedsWishlistCommand}" Style="{StaticResource CardHoverBtn}" Margin="0,0,14,0">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="📝" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Needs Wishlist" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Post urgent needs for your org" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Command="{Binding ChatCommand}" Style="{StaticResource CardHoverBtn}">
                                <Border Style="{StaticResource GlassCard}">
                                    <StackPanel>
                                        <TextBlock Text="💬" FontSize="30" Margin="0,0,0,10"/>
                                        <TextBlock Text="Messages" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                        <TextBlock Text="Chat with donors" FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>