<Window x:Class="KapwaKuha.View.BrowseItemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Browse Items"
          Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="380" Height="380" Opacity="0.12"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Browse Items" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#CAF0F8" FontSize="12" Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="20,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter bar -->
                <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍  Filter by Category:" FontSize="13"
                                   Foreground="#03045E" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border CornerRadius="8" BorderBrush="#90E0EF" BorderThickness="1.5"
                                Background="#F0F8FB">
                            <ComboBox SelectedValue="{Binding FilterCategory}"
                                      Width="180" Height="34" Background="Transparent"
                                      BorderThickness="0" Padding="10,0" FontSize="12">
                                <ComboBoxItem Content="All" IsSelected="True"/>
                                <ComboBoxItem Content="Clothing"/>
                                <ComboBoxItem Content="Food"/>
                                <ComboBoxItem Content="Electronics"/>
                                <ComboBoxItem Content="Medicine"/>
                                <ComboBoxItem Content="School Supplies"/>
                            </ComboBox>
                        </Border>
                        <TextBlock Text="{Binding Items.Count, StringFormat='{}{0} item(s) available'}"
                                   Foreground="#5E7A8A" FontSize="12"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Busy indicator -->
                <Border Grid.Row="2" Background="Transparent"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Loading items..." FontSize="14" Foreground="#0077B6"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Item cards -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Items}" Margin="0,4,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="210" CornerRadius="16" Margin="0,0,14,14"
                                        Background="White" Cursor="Hand">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B4D8" BlurRadius="18"
                                                          ShadowDepth="0" Opacity="0.14"/>
                                    </Border.Effect>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectItemCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <!-- Image area -->
                                        <Border Height="110" CornerRadius="16,16,0,0" ClipToBounds="True">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#EBF7FB" Offset="0"/>
                                                    <GradientStop Color="#CAF0F8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="📦" FontSize="44"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- Info -->
                                        <StackPanel Margin="12,10,12,12">
                                            <TextBlock Text="{Binding Item_Name}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="#03045E" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Donor_Name, StringFormat='by {0}'}"
                                                       FontSize="10" Foreground="#5E7A8A" Margin="0,2,0,6"/>
                                            <!-- Badges row -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Border CornerRadius="6" Padding="6,3" Margin="0,0,5,0"
                                                        Background="#EBF7FB">
                                                    <TextBlock Text="{Binding Category_Name}"
                                                               FontSize="9" Foreground="#0077B6"/>
                                                </Border>
                                                <Border CornerRadius="6" Padding="6,3"
                                                        Background="{Binding StatusBadgeBackground}">
                                                    <TextBlock Text="{Binding Item_Condition}"
                                                               FontSize="9"
                                                               Foreground="{Binding StatusBadgeColor}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding StorageDaysDisplay}"
                                                       FontSize="10" Foreground="#5E7A8A"/>
                                            <!-- Claim button -->
                                            <Border Background="#00B4D8" CornerRadius="8"
                                                    Margin="0,8,0,0" Padding="0,7">
                                                <TextBlock Text="Claim This Item →" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="White"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>