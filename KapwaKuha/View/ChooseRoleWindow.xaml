<Window x:Class="KapwaKuha.View.ChooseRoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Choose Your Role"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" 
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="KapwaBtn" TargetType="Button">
            <Setter Property="Background" Value="#00A8E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#008CBA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoleCardStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">

                        <Border x:Name="MainBorder" CornerRadius="20" BorderThickness="1.5" Height="140">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="#33FFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>

                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="30" ShadowDepth="0" Opacity="0.16"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="Indicator" Width="20" Height="20" CornerRadius="10" 
                                        BorderThickness="2" BorderBrush="#9CA3AF" HorizontalAlignment="Left"/>
                                <Border x:Name="Dot" Width="10" Height="10" CornerRadius="5" 
                                        Background="#00A8E8" HorizontalAlignment="Left" Margin="5" Opacity="0"/>

                                <TextBlock Grid.Row="1" Text="{TemplateBinding Tag}" FontSize="32" 
                                           VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,25"/>
                                <TextBlock Grid.Row="1" Text="{TemplateBinding Content}" FontSize="16" 
                                           FontWeight="SemiBold" Foreground="#0A2540" 
                                           VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="#00A8E8"/>
                                <Setter TargetName="Dot" Property="Opacity" Value="1"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#00A8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#00A8E8" Offset="0"/>
                    <GradientStop Color="#0077B6" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse Width="400" Height="400" Fill="#1AFFFFFF" Margin="-100,-100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <StackPanel Margin="60" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,40">

                    <Image Source="https://i.imgur.com/FHFRQxB.png" 
                   Width="60" Height="60" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>
                    <TextBlock Text="KapwaKuha" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="One-stop platform to manage your donations and assistance requests." 
                           Foreground="White" FontSize="36" FontWeight="SemiBold" 
                           TextWrapping="Wrap" Margin="0,0,0,40" LineHeight="46"/>

                <Border CornerRadius="16" Height="300" HorizontalAlignment="Stretch" BorderBrush="#4DFFFFFF" BorderThickness="1">
                    <Border.Background>
                        <ImageBrush ImageSource="https://i.imgur.com/W3AE99R.jpeg" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="#F0F8FF">
            <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.03" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">

                <Grid HorizontalAlignment="Left" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Source="https://i.imgur.com/FHFRQxB.png" 
                     Width="100" Height="100" Stretch="Uniform" 
                     VerticalAlignment="Top" Margin="-25,5,10,0"/>

                    <TextBlock Grid.Column="1" FontSize="32" FontWeight="Bold" 
                         Foreground="#0A2540" VerticalAlignment="Center" Margin="-30,0,0,-5">
                  <Run Text="Welcome to Kapwa"/><Run Foreground="#FF00A8E8" Text="Kuha"/>
                    </TextBlock>
                </Grid>

                <TextBlock Text="Let's personalize your KapwaKuha experience." FontSize="16" Foreground="#6B7280" Margin="0,-20,0,40"/>

                <TextBlock Text="Are you here to donate or receive assistance?" FontSize="14" FontWeight="SemiBold" Foreground="#0A2540" Margin="0,-20,0,16"/>

                <Grid Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="🤲 Donor" 
                      Style="{StaticResource KapwaBtn}" Height="55" FontSize="16" Margin="0,0,0,-20"/>

                    <Button Grid.Column="2" Content="❤️ Beneficiary" 
                      Style="{StaticResource KapwaBtn}" Height="55" FontSize="16" Margin="0,0,0,-20"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Grid>
</Window>