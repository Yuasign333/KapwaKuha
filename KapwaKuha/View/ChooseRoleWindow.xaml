<Window x:Class="KapwaKuha.View.ChooseRoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        Title="KapwaKuha — Choose Role"
        Width="480" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="RoleCardBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background gradient -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#ADE8F4" Offset="0.5"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Decorative circles -->
        <Ellipse Width="340" Height="340" Opacity="0.15"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="280" Height="280" Opacity="0.12"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-60,0,0,-60">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0077B6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Exit button top-left -->
        <Button Command="{Binding ExitCommand}"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="12,12,0,0" Width="32" Height="32"
                Style="{StaticResource RoleCardBtn}"
                FontSize="16" Content="✕" Foreground="#03045E"/>

        <!-- Center card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="360" CornerRadius="24" Padding="36,32">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFFEE" Offset="0"/>
                    <GradientStop Color="#E8F7FBCC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00B4D8" BlurRadius="40" ShadowDepth="0" Opacity="0.18"/>
            </Border.Effect>
            <StackPanel>
                <!-- Logo circle -->
                <Border Width="72" Height="72" CornerRadius="36" Margin="0,0,0,12"
                        HorizontalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00B4D8" Offset="0"/>
                            <GradientStop Color="#0077B6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="K" FontSize="36" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="KapwaKuha" FontSize="22" FontWeight="Bold"
                           Foreground="#03045E" HorizontalAlignment="Center"/>
                <TextBlock Text="Donate is something they await."
                           FontSize="12" Foreground="#5E7A8A"
                           HorizontalAlignment="Center" Margin="0,2,0,24"/>

                <!-- Donor card -->
                <Button Command="{Binding DonorCommand}" Margin="0,0,0,12"
                        Style="{StaticResource RoleCardBtn}">
                    <Border Background="#EBF7FB" CornerRadius="14"
                            BorderBrush="#90E0EF" BorderThickness="1.5" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                                    Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                        <GradientStop Color="#90E0EF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🤲" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Donor" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                <TextBlock Text="Post items &amp; track your impact"
                                           FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="→" FontSize="20"
                                       Foreground="#00B4D8" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Button>

                <!-- Beneficiary card -->
                <Button Command="{Binding BeneficiaryCommand}"
                        Style="{StaticResource RoleCardBtn}">
                    <Border Background="#F0F8FF" CornerRadius="14"
                            BorderBrush="#ADE8F4" BorderThickness="1.5" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                                    Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0077B6" Offset="0"/>
                                        <GradientStop Color="#00B4D8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🙏" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Beneficiary" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                <TextBlock Text="Browse &amp; claim donated items"
                                           FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="→" FontSize="20"
                                       Foreground="#0077B6" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Button>

                <TextBlock Text="Made by Yuan, Aisha, and Mika • BSIT 2A"
                           FontSize="10" Foreground="#5E7A8A"
                           HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>