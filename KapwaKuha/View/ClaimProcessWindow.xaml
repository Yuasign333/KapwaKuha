<Window x:Class="KapwaKuha.View.ClaimProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        Title="KapwaKuha — Claim Process"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8"
        FontFamily="Segoe UI">

    <!-- ──────────────────────────────────────────────────────────────────────
         GLOBAL RESOURCES
         Color System based on KapwaKuha brand (teal/blue + dark navy)
         Parallel to CarRentals purple color system in App.xaml
    ────────────────────────────────────────────────────────────────────────── -->
    <Window.Resources>

        <!-- ── BRAND COLORS ── -->
        <SolidColorBrush x:Key="KapwaTeal"       Color="#00B4D8"/>
        <SolidColorBrush x:Key="KapwaTealDark"   Color="#0077B6"/>
        <SolidColorBrush x:Key="KapwaTealLight"  Color="#90E0EF"/>
        <SolidColorBrush x:Key="KapwaNavy"       Color="#03045E"/>
        <SolidColorBrush x:Key="KapwaBackground" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="KapwaSurface"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="KapwaText"       Color="#03045E"/>
        <SolidColorBrush x:Key="KapwaSubText"    Color="#5E7A8A"/>
        <SolidColorBrush x:Key="KapwaLost"       Color="#E63946"/>
        <SolidColorBrush x:Key="KapwaFound"      Color="#00B4D8"/>
        <SolidColorBrush x:Key="KapwaClaimed"    Color="#9E9E9E"/>
        <SolidColorBrush x:Key="KapwaSuccess"    Color="#2DC653"/>

        <!-- ── GLOBAL BUTTON STYLE ── -->
        <Style x:Key="KapwaButtonStyle" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource KapwaTeal}"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Padding"           Value="20,10"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource KapwaTealDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── BACK/SECONDARY BUTTON STYLE ── -->
        <Style x:Key="KapwaSecondaryButton" TargetType="Button" BasedOn="{StaticResource KapwaButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource KapwaTeal}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource KapwaTeal}"
                                BorderThickness="1.5"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F7FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CARD BORDER STYLE ── -->
        <Style x:Key="KapwaCard" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource KapwaSurface}"/>
            <Setter Property="CornerRadius"   Value="12"/>
            <Setter Property="Padding"        Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06"
                                      BlurRadius="12" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── STATUS BADGE STYLE (converts Item_Status to colored pill) ── -->
        <!-- StatusBadgeColor is computed in LostItemModel.StatusBadgeColor -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>

        <!-- ── DATA GRID STYLE ── -->
        <Style x:Key="KapwaDataGrid" TargetType="DataGrid">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="RowBackground"        Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F7FBFD"/>
            <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5EEF2"/>
            <Setter Property="SelectionMode"        Value="Single"/>
            <Setter Property="CanUserAddRows"       Value="False"/>
            <Setter Property="CanUserDeleteRows"    Value="False"/>
            <Setter Property="CanUserResizeRows"    Value="False"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
            <Setter Property="HeadersVisibility"    Value="Column"/>
            <Setter Property="FontSize"             Value="13"/>
            <Setter Property="RowHeight"            Value="44"/>
            <Setter Property="ColumnHeaderHeight"   Value="38"/>
        </Style>

        <!-- ── TEXTBOX INPUT STYLE ── -->
        <Style x:Key="KapwaInput" TargetType="TextBox">
            <Setter Property="Background"     Value="#F5F9FC"/>
            <Setter Property="BorderBrush"    Value="#C5D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"        Value="10,8"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="Foreground"     Value="{StaticResource KapwaText}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource KapwaTeal}"/>
                                <Setter Property="Background"  Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── COMBOBOX STYLE ── -->
        <Style x:Key="KapwaCombo" TargetType="ComboBox">
            <Setter Property="Background"     Value="#F5F9FC"/>
            <Setter Property="BorderBrush"    Value="#C5D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"        Value="10,8"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="Height"         Value="40"/>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════
         ROOT LAYOUT
    ══════════════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <!-- Header bar -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="36"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── ROW 0: HEADER BAR ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource KapwaNavy}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back button -->
                <Button Grid.Column="0"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource KapwaSecondaryButton}"
                        Foreground="White"
                        BorderBrush="White"
                        Padding="14,6"
                        Content="← Back"
                        VerticalAlignment="Center"/>

                <!-- Center logo + title -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <!-- Stylized K logo using text — replace with actual image when available -->
                    <Border Background="{StaticResource KapwaTeal}"
                            CornerRadius="20"
                            Width="36" Height="36"
                            Margin="0,0,10,0">
                        <TextBlock Text="K" FontSize="18" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="KapwaKuha"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Claim Process Portal"
                                   FontSize="11"
                                   Foreground="{StaticResource KapwaTealLight}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Admin label -->
                <TextBlock Grid.Column="2"
                           Text="{Binding AdminLabel}"
                           Foreground="{StaticResource KapwaTealLight}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── ROW 1: MAIN CONTENT ────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <!-- Left: Found items list -->
                <ColumnDefinition Width="16"/>
                <!-- Gutter -->
                <ColumnDefinition Width="2*"/>
                <!-- Right: Claim form -->
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL: Found Items DataGrid ─────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource KapwaCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Panel header -->
                        <RowDefinition Height="*"/>
                        <!-- DataGrid -->
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📦 Found Items"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource KapwaNavy}"/>
                            <TextBlock Text="Items confirmed found — awaiting verified claim"
                                       FontSize="11"
                                       Foreground="{StaticResource KapwaSubText}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Refresh Button -->
                        <Button Grid.Column="1"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource KapwaSecondaryButton}"
                                Content="⟳ Refresh"
                                Padding="12,6"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <!-- Found Items DataGrid -->
                    <DataGrid Grid.Row="1"
                              Style="{StaticResource KapwaDataGrid}"
                              ItemsSource="{Binding FoundItems}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                        <DataGrid.Columns>

                            <!-- Item ID -->
                            <DataGridTextColumn Header="Item ID"
                                                Binding="{Binding Item_ID}"
                                                Width="80" IsReadOnly="True"/>

                            <!-- Item Name -->
                            <DataGridTextColumn Header="Item Name"
                                                Binding="{Binding Item_Name}"
                                                Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Category -->
                            <DataGridTextColumn Header="Category"
                                                Binding="{Binding Category_Name}"
                                                Width="100" IsReadOnly="True"/>

                            <!-- Condition -->
                            <DataGridTextColumn Header="Condition"
                                                Binding="{Binding Item_Condition}"
                                                Width="90" IsReadOnly="True"/>

                            <!-- Status Badge Column -->
                            <DataGridTemplateColumn Header="Status" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource StatusBadge}"
                                                Background="{Binding StatusBadgeColor}"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Item_Status}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Storage Days -->
                            <DataGridTextColumn Header="Storage"
                                                Binding="{Binding StorageDaysDisplay}"
                                                Width="120" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Foreground" Value="#5E7A8A"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Donor -->
                            <DataGridTextColumn Header="Reported By"
                                                Binding="{Binding Donor_Name}"
                                                Width="110" IsReadOnly="True"/>

                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </Border>

            <!-- ── RIGHT PANEL: Claim Process Form ──────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource KapwaCard}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Form Title -->
                        <TextBlock Text="Process Claim"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource KapwaNavy}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Verify identity and release the item"
                                   FontSize="11"
                                   Foreground="{StaticResource KapwaSubText}"
                                   Margin="0,0,0,20"/>

                        <!-- ── SELECTED ITEM SUMMARY CARD ── -->
                        <Border CornerRadius="8"
                                Background="#EBF7FB"
                                Padding="14"
                                Margin="0,0,0,16"
                                Visibility="{Binding IsItemSelected,
                                             Converter={x:Static BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Selected Item"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource KapwaTealDark}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding SelectedItem.Item_Name}"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource KapwaNavy}"/>
                                <TextBlock Text="{Binding SelectedItem.Item_ID}"
                                           FontSize="11"
                                           Foreground="{StaticResource KapwaSubText}"/>
                                <Separator Margin="0,8"/>
                                <!-- Storage Days — key metric -->
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏱ " FontSize="13"/>
                                    <TextBlock Text="{Binding StorageDaysDisplay}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource KapwaTealDark}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedItem.Item_Condition,
                                                  StringFormat='Condition: {0}'}"
                                           FontSize="11"
                                           Foreground="{StaticResource KapwaSubText}"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedItem.Category_Name,
                                                  StringFormat='Category: {0}'}"
                                           FontSize="11"
                                           Foreground="{StaticResource KapwaSubText}"/>
                            </StackPanel>
                        </Border>

                        <!-- No item selected placeholder -->
                        <Border CornerRadius="8"
                                Background="#F5F9FC"
                                BorderBrush="#DDE8EE"
                                BorderThickness="1.5"
                                Padding="14"
                                Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsItemSelected}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="← Select a Found item from the list to begin"
                                       FontSize="12"
                                       Foreground="{StaticResource KapwaSubText}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- ── FORM LABEL + BENEFICIARY ── -->
                        <TextBlock Text="Beneficiary" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource KapwaNavy}"
                                   Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource KapwaCombo}"
                                  ItemsSource="{Binding Beneficiaries}"
                                  SelectedItem="{Binding SelectedBeneficiary, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Margin="0,0,0,14"
                                  IsEnabled="{Binding IsItemSelected}"/>

                        <!-- ── VERIFICATION NOTES ── -->
                        <TextBlock Text="Verification Notes" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource KapwaNavy}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Describe how you verified the claimer's identity (ID, item description, etc.)"
                                   FontSize="11"
                                   Foreground="{StaticResource KapwaSubText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource KapwaInput}"
                                 Text="{Binding VerificationNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Margin="0,0,0,20"
                                 IsEnabled="{Binding IsItemSelected}"/>

                        <!-- ── PROCESS CLAIM BUTTON ── -->
                        <Button Command="{Binding ProcessClaimCommand}"
                                Style="{StaticResource KapwaButtonStyle}"
                                Background="{StaticResource KapwaSuccess}"
                                Content="✅ Release Item to Beneficiary"
                                Height="44"
                                FontSize="14"
                                IsEnabled="{Binding IsItemSelected}"/>

                        <!-- Busy indicator -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Processing..." FontSize="12"
                                       Foreground="{StaticResource KapwaTeal}"/>
                        </StackPanel>

                        <!-- ── IMPACT REMINDER ── -->
                        <Border CornerRadius="8"
                                Background="#F0FFF4"
                                Padding="12"
                                Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="💙 Community Impact"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#1B5E20"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Every claim processed returns something precious to someone in the community. Kapwa — we are each other."
                                           FontSize="11"
                                           Foreground="#388E3C"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── ROW 2: STATUS BAR ──────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource KapwaNavy}" Padding="20,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource KapwaTealLight}"
                       FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
