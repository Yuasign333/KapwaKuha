<Window x:Class="KapwaKuha.View.ClaimProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ClaimProcessDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Claim Process"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" ResizeMode="CanResize">
    <Grid>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.07" Stretch="UniformToFill"/>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="340" Height="340" Opacity="0.13" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-80,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#AAFFFFFF">
                <Border.Effect>
                    <DropShadowEffect Color="#0077B6" BlurRadius="10" ShadowDepth="0" Opacity="0.10"/>
                </Border.Effect>
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}" Style="{StaticResource LinkBtn}"
                            Content="← Back" FontSize="13" Foreground="#03045E"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="Claim Process" FontSize="17" FontWeight="Bold" Foreground="#03045E"/>
                        <TextBlock Text="Verify and release found items to beneficiaries"
                                   FontSize="11" Foreground="#5E7A8A"/>
                    </StackPanel>
                    <Border Grid.Column="2" CornerRadius="14" Padding="10,5" VerticalAlignment="Center"
                            Background="#4DFFFFFF" BorderBrush="#B390E0EF" BorderThickness="1">
                        <TextBlock Text="{Binding AdminLabel}" FontSize="11" Foreground="#03045E" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Found items list -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="📦 Found Items" FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                <TextBlock Text="Items confirmed found — awaiting verified claim"
                                           FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                                    Style="{StaticResource LinkBtn}" Content="⟳ Refresh" FontSize="12"/>
                        </Grid>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding FoundItems}"
                                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  BorderThickness="0" Background="Transparent"
                                  RowBackground="Transparent" AlternatingRowBackground="#11CAF0F8"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#22B390E0EF"
                                  RowHeight="42" ColumnHeaderHeight="36" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Item_ID}" Width="80"/>
                                <DataGridTextColumn Header="Item Name" Binding="{Binding Item_Name}" Width="*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category_Name}" Width="100"/>
                                <DataGridTemplateColumn Header="Status" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="7,2"
                                                    Background="{Binding StatusColor}"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Item_Status}" Foreground="White"
                                                           FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Storage" Binding="{Binding StorageDaysDisplay}" Width="120"/>
                                <DataGridTextColumn Header="Reported By" Binding="{Binding Donor_Name}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Claim form -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Process Claim" FontSize="15" FontWeight="Bold"
                                       Foreground="#03045E" Margin="0,0,0,4"/>
                            <TextBlock Text="Verify identity and release the item"
                                       FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,16"/>

                            <!-- Selected item summary -->
                            <Border CornerRadius="12" Padding="14" Margin="0,0,0,14"
                                    Background="#4DFFFFFF" BorderBrush="#B390E0EF" BorderThickness="1"
                                    Visibility="{Binding IsItemSelected, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="SELECTED ITEM" FontSize="10" FontWeight="Bold"
                                               Foreground="#0077B6" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SelectedItem.Item_Name}"
                                               FontSize="15" FontWeight="Bold" Foreground="#03045E"/>
                                    <TextBlock Text="{Binding SelectedItem.Item_ID}"
                                               FontSize="11" Foreground="#5E7A8A"/>
                                    <Rectangle Height="1" Fill="White" Margin="0,8"/>
                                    <TextBlock Text="{Binding StorageDaysDisplay}"
                                               FontSize="12" Foreground="#0077B6" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <!-- Empty state -->
                            <Border CornerRadius="12" Padding="14" Margin="0,0,0,14"
                                    Background="#4DFFFFFF" BorderBrush="#B390E0EF" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsItemSelected}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="← Select a Found item from the list"
                                           HorizontalAlignment="Center" Foreground="#5E7A8A" FontSize="12"/>
                            </Border>

                            <!-- Beneficiary -->
                            <TextBlock Text="Beneficiary" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource GlassInputBorder}">
                                <ComboBox ItemsSource="{Binding Beneficiaries}"
                                          SelectedItem="{Binding SelectedBeneficiary}"
                                          DisplayMemberPath="DisplayName"
                                          Background="Transparent" BorderThickness="0"
                                          Height="34" VerticalContentAlignment="Center" FontSize="12"
                                          IsEnabled="{Binding IsItemSelected}"/>
                            </Border>

                            <!-- Verification notes -->
                            <TextBlock Text="Verification Notes" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,4,0,4"/>
                            <TextBlock Text="Describe how you verified the claimer's identity"
                                       FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,6"/>
                            <Border Style="{StaticResource GlassInputBorder}" Margin="0,0,0,20">
                                <TextBox Text="{Binding VerificationNotes, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent"
                                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalContentAlignment="Top" FontSize="12"
                                         IsEnabled="{Binding IsItemSelected}"/>
                            </Border>

                            <!-- Release button -->
                            <Button Command="{Binding ProcessClaimCommand}"
                                    Style="{StaticResource GradientButton}"
                                    IsEnabled="{Binding IsItemSelected}">
                                <TextBlock Text="✅ Release Item to Beneficiary"/>
                            </Button>

                            <!-- Busy indicator -->
                            <TextBlock Text="Processing..." HorizontalAlignment="Center"
                                       Foreground="#0077B6" FontSize="12" Margin="0,10,0,0"
                                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#CC03045E">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#90E0EF"
                           FontSize="11" Margin="14,0" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>