<Window x:Class="KapwaKuha.View.DonorDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Donor Dashboard"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F0F8FF">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SIDEBAR ── -->
        <Border Grid.Column="0" Background="#03045E" ClipToBounds="True">
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="KapwaKuha" FontSize="16" FontWeight="Bold"
                           Foreground="White" Margin="16,0,0,4"/>
                <TextBlock Text="{Binding UserLabel}" FontSize="10"
                           Foreground="#90E0EF" Margin="16,0,0,16"/>
                <Separator Background="#0077B6" Margin="12,0,12,12"/>

                <Button Command="{Binding PostItemCommand}" Content="🤲  Post Item"
                        Background="Transparent" BorderThickness="0" Foreground="#90E0EF"
                        FontSize="13" HorizontalContentAlignment="Left"
                        Padding="16,10" Cursor="Hand"/>
                <Button Command="{Binding ActiveListingsCommand}" Content="📋  Active Listings"
                        Background="Transparent" BorderThickness="0" Foreground="#90E0EF"
                        FontSize="13" HorizontalContentAlignment="Left"
                        Padding="16,10" Cursor="Hand"/>
                <Button Command="{Binding MyImpactCommand}" Content="💙  My Impact"
                        Background="Transparent" BorderThickness="0" Foreground="#90E0EF"
                        FontSize="13" HorizontalContentAlignment="Left"
                        Padding="16,10" Cursor="Hand"/>
                <Button Command="{Binding HighPriorityNeedsCommand}" Content="🚨  High-Priority Needs"
                        Background="Transparent" BorderThickness="0" Foreground="#90E0EF"
                        FontSize="13" HorizontalContentAlignment="Left"
                        Padding="16,10" Cursor="Hand"/>
                <Button Command="{Binding ChatCommand}" Content="💬  Messages"
                        Background="Transparent" BorderThickness="0" Foreground="#90E0EF"
                        FontSize="13" HorizontalContentAlignment="Left"
                        Padding="16,10" Cursor="Hand"/>
                <Separator Background="#0077B6" Margin="12,8"/>
                <Button Command="{Binding LogoutCommand}" Content="⬅  Logout"
                        Background="Transparent" BorderThickness="0" Foreground="#C0304A"
                        FontSize="13" HorizontalContentAlignment="Left"
                        Padding="16,10" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- ── MAIN ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding HamburgerCommand}"
                            Content="☰" Foreground="White" Background="Transparent"
                            BorderThickness="0" FontSize="20" Cursor="Hand"
                            VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding WelcomeText}"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding UserLabel}"
                               Foreground="#90E0EF" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Dashboard cards -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <TextBlock Text="What would you like to do today?"
                               FontSize="18" FontWeight="Bold" Foreground="#03045E"
                               Margin="0,0,0,20"/>

                    <UniformGrid Rows="2" Columns="2" HorizontalAlignment="Stretch">
                        <!-- Post Item card -->
                        <Button Command="{Binding PostItemCommand}" Margin="0,0,12,12"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Border Background="White" CornerRadius="14" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00B4D8" BlurRadius="12"
                                                      ShadowDepth="2" Opacity="0.10"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="🤲" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="Post an Item" FontSize="14"
                                               FontWeight="Bold" Foreground="#03045E"/>
                                    <TextBlock Text="Donate directly or to the public"
                                               FontSize="11" Foreground="#5E7A8A"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- My Impact card -->
                        <Button Command="{Binding MyImpactCommand}" Margin="0,0,0,12"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Border Background="White" CornerRadius="14" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00B4D8" BlurRadius="12"
                                                      ShadowDepth="2" Opacity="0.10"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="💙" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="My Impact Dashboard" FontSize="14"
                                               FontWeight="Bold" Foreground="#03045E"/>
                                    <TextBlock Text="See your community contribution"
                                               FontSize="11" Foreground="#5E7A8A"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- High-Priority card -->
                        <Button Command="{Binding HighPriorityNeedsCommand}" Margin="0,0,12,0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Border Background="White" CornerRadius="14" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00B4D8" BlurRadius="12"
                                                      ShadowDepth="2" Opacity="0.10"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="🚨" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="High-Priority Needs" FontSize="14"
                                               FontWeight="Bold" Foreground="#03045E"/>
                                    <TextBlock Text="Respond to urgent community requests"
                                               FontSize="11" Foreground="#5E7A8A"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Active Listings card -->
                        <Button Command="{Binding ActiveListingsCommand}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Border Background="White" CornerRadius="14" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00B4D8" BlurRadius="12"
                                                      ShadowDepth="2" Opacity="0.10"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="📋" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="Active Listings" FontSize="14"
                                               FontWeight="Bold" Foreground="#03045E"/>
                                    <TextBlock Text="View and manage your posted items"
                                               FontSize="11" Foreground="#5E7A8A"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>