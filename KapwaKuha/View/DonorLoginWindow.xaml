<Window x:Class="KapwaKuha.View.DonorLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Donor Login"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="KapwaBtn" TargetType="Button">
            <Setter Property="Background" Value="#00B4D8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0077B6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#0077B6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   TextDecorations="Underline"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#F0F8FF">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="340" CornerRadius="20" Padding="32,28" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="#00B4D8" BlurRadius="30" ShadowDepth="0" Opacity="0.12"/>
            </Border.Effect>
            <StackPanel>
                <Button Command="{Binding BackCommand}" HorizontalAlignment="Left"
                        Style="{StaticResource LinkBtn}" Content="← Back" Margin="0,0,0,14"/>

                <Border Width="56" Height="56" CornerRadius="28" HorizontalAlignment="Center"
                        Margin="0,0,0,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00B4D8" Offset="0"/>
                            <GradientStop Color="#0077B6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🤲" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Donor Login" FontSize="20" FontWeight="Bold"
                           Foreground="#03045E" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Username" FontSize="11" Foreground="#5E7A8A"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold"
                           Foreground="#03045E" Margin="0,0,0,4"/>
                <Border BorderBrush="#90E0EF" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,14">
                    <TextBox Text="{Binding CurrentUser.UserID, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Background="Transparent"
                             Padding="10,8" FontSize="13"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold"
                           Foreground="#03045E" Margin="0,0,0,4"/>
                <Border BorderBrush="#90E0EF" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,6">
                    <PasswordBox x:Name="PwBox" BorderThickness="0" Background="Transparent"
                                 Padding="10,8" FontSize="13"/>
                </Border>

                <!-- Error -->
                <Border Background="#FFF0F5" CornerRadius="6" Padding="10,6" Margin="0,0,0,10"
                        Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                               FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <Button Content="Login →" Style="{StaticResource KapwaBtn}" Margin="0,4,0,12"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PwBox}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource LinkBtn}" Content="Forgot Password?"
                            Command="{Binding ForgotPasswordCommand}" Margin="0,0,16,0"/>
                    <Button Style="{StaticResource LinkBtn}" Content="Create Account"
                            Command="{Binding SignUpCommand}"/>
                </StackPanel>

                <TextBlock Text="Default: juandc / donor123"
                           FontSize="10" Foreground="#AAAAAA"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>