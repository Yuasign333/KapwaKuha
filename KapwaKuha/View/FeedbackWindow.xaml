<Window x:Class="KapwaKuha.View.FeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Rate This Donation"
        Height="520" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Border CornerRadius="20" Style="{StaticResource GlassCard}" Margin="0">
        <Grid Margin="40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="⭐ Rate This Donation"
                       FontSize="24" FontWeight="Bold" Foreground="#0A2540"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Grid.Row="1" Text="{Binding DonorLabel}"
                       FontSize="13" Foreground="#6B7280"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <!-- Star selector -->
            <!-- Star selector — half-star support (10 clickable halves = 5 stars) -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
            HorizontalAlignment="Center" Margin="0,0,0,4">
                <!-- Star 1 -->
                <Grid Width="36" Height="40">
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="1"
                Width="18" HorizontalAlignment="Left"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◐" FontSize="34" Margin="0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half1Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="2"
                Width="18" HorizontalAlignment="Right"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◑" FontSize="34" Margin="0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half2Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
                <!-- Star 2 -->
                <Grid Width="36" Height="40">
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="3"
                Width="18" HorizontalAlignment="Left"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◐" FontSize="34">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half3Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="4"
                Width="18" HorizontalAlignment="Right"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◑" FontSize="34">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half4Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
                <!-- Star 3 -->
                <Grid Width="36" Height="40">
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="5"
                Width="18" HorizontalAlignment="Left"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◐" FontSize="34">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half5Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="6"
                Width="18" HorizontalAlignment="Right"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◑" FontSize="34">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half6Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
                <!-- Star 4 -->
                <Grid Width="36" Height="40">
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="7"
                Width="18" HorizontalAlignment="Left"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◐" FontSize="34">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half7Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="8"
                Width="18" HorizontalAlignment="Right"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◑" FontSize="34">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half8Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
                <!-- Star 5 -->
                <Grid Width="36" Height="40">
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="9"
                Width="18" HorizontalAlignment="Left"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◐" FontSize="34">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half9Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding SetHalfStarCommand}" CommandParameter="10"
                Width="18" HorizontalAlignment="Right"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="◑" FontSize="34">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Half10Filled}" Value="True">
                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Star label -->
            <TextBlock Grid.Row="3" Text="{Binding StarDisplayLabel}"
           FontSize="14" FontWeight="SemiBold" Foreground="#F59E0B"
           HorizontalAlignment="Center" Margin="0,0,0,16"/>



            <!-- Comment box -->
            <TextBlock Grid.Row="4" Text="Leave a comment (optional)"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#374151" Margin="0,0,0,8"/>
            <Border Grid.Row="5" Style="{StaticResource GlassInputBorder}" CornerRadius="12">
                <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#0A2540" FontSize="13" Padding="14,10"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="80"/>
            </Border>

            <!-- Error banner -->
            <Border Grid.Row="5" Background="#FEE2E2" CornerRadius="8" Padding="12,8"
                    VerticalAlignment="Bottom" Margin="0,0,0,0"
                    Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Action buttons -->
            <Grid Grid.Row="6" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel"
                        Style="{StaticResource OutlineBtn}"
                        Command="{Binding CancelCommand}" Height="46"/>
                <Button Grid.Column="2" Content="Submit Feedback"
                        Style="{StaticResource GradientButton}"
                        Command="{Binding SubmitCommand}" Height="46"/>
            </Grid>
        </Grid>
    </Border>
</Window>