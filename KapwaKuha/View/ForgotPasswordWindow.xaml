<Window x:Class="KapwaKuha.View.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Forgot Password"
          Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="320" Height="320" Opacity="0.12"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-80,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="400" CornerRadius="22" Padding="36,32" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="#00B4D8" BlurRadius="32" ShadowDepth="0" Opacity="0.16"/>
            </Border.Effect>
            <StackPanel>
                <!-- Icon -->
                <Border Width="52" Height="52" CornerRadius="26" HorizontalAlignment="Center"
                        Margin="0,0,0,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00B4D8" Offset="0"/>
                            <GradientStop Color="#0077B6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🔑" FontSize="24"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Forgot Password" FontSize="20" FontWeight="Bold"
                           Foreground="#03045E" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="We'll verify your identity first."
                           FontSize="12" Foreground="#5E7A8A"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Error -->
                <Border Background="#FFF0F5" CornerRadius="8" Padding="12,8" Margin="0,0,0,14"
                        Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- STEP 1: Username lookup -->
                <StackPanel Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Username / User ID" FontSize="12" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,6"/>
                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                            Padding="10,0" Background="#F0F8FB" Margin="0,0,0,20">
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Background="Transparent" BorderThickness="0"
                                 Foreground="#03045E" FontSize="13" VerticalContentAlignment="Center"/>
                    </Border>

                    <Button Command="{Binding FindAccountCommand}"
                            Height="44" FontSize="13" FontWeight="Bold"
                            Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00B4D8" Offset="0"/>
                                <GradientStop Color="#0077B6" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <TextBlock Text="Find My Account"/>
                    </Button>
                </StackPanel>

                <!-- STEP 2: Answer + new password -->
                <StackPanel Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}}">
                    <!-- Security question shown -->
                    <Border Background="#EBF7FB" CornerRadius="8" Padding="12,10" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Security Question" FontSize="10" Foreground="#0077B6"
                                       FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding SecurityQuestion}" FontSize="13"
                                       Foreground="#03045E" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Your Answer" FontSize="12" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,6"/>
                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                            Padding="10,0" Background="#F0F8FB" Margin="0,0,0,12">
                        <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Background="Transparent" BorderThickness="0"
                                 Foreground="#03045E" FontSize="13" VerticalContentAlignment="Center"/>
                    </Border>

                    <TextBlock Text="New Password  (min 6 chars)" FontSize="12" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,6"/>
                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                            Padding="10,0" Background="#F0F8FB" Margin="0,0,0,12">
                        <PasswordBox x:Name="NewPwBox" Height="34" Background="Transparent"
                                     BorderThickness="0" Foreground="#03045E"
                                     FontSize="12" Padding="0,8,0,0"/>
                    </Border>

                    <TextBlock Text="Confirm New Password" FontSize="12" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,6"/>
                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                            Padding="10,0" Background="#F0F8FB" Margin="0,0,0,20">
                        <PasswordBox x:Name="ConfirmPwBox" Height="34" Background="Transparent"
                                     BorderThickness="0" Foreground="#03045E"
                                     FontSize="12" Padding="0,8,0,0"/>
                    </Border>

                    <Button x:Name="ResetBtn" Height="44" FontSize="13" FontWeight="Bold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="ResetBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2DC653" Offset="0"/>
                                <GradientStop Color="#1A9940" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <TextBlock Text="Reset Password ✓"/>
                    </Button>
                </StackPanel>

                <!-- Back -->
                <Button Command="{Binding BackCommand}" Margin="0,16,0,0"
                        HorizontalAlignment="Left" Background="Transparent"
                        BorderThickness="0" Foreground="#0077B6" FontSize="12" Cursor="Hand">
                    <TextBlock Text="← Back to Login" TextDecorations="Underline"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>