<Window x:Class="KapwaKuha.View.HighPriorityNeedsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — High-Priority Needs"
        Height="620" Width="960"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#C0304A">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🚨 " FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="HIGH-PRIORITY NEEDS" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#FFB3B3" FontSize="12" Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Cards area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16,12">
                        <Border.Effect>
                            <DropShadowEffect Color="#C0304A" BlurRadius="12" ShadowDepth="0" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Organizations and beneficiaries post urgent needs here. Donate an item that matches their request to help fulfill it."
                                       FontSize="12" Foreground="#5E7A8A" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding NeedsPosts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="280" CornerRadius="16" Margin="0,0,14,14"
                                        Background="White" Padding="0,0,0,14">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="16"
                                                          ShadowDepth="0" Opacity="0.08"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <!-- Urgency color bar -->
                                        <Border Height="6" CornerRadius="16,16,0,0"
                                                Background="{Binding UrgencyTextColor}"/>

                                        <StackPanel Margin="16,12,16,0">
                                            <!-- Urgency badge -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border CornerRadius="6" Padding="8,3"
                                                        Background="{Binding UrgencyColor}">
                                                    <TextBlock Text="{Binding Urgency}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="{Binding UrgencyTextColor}"/>
                                                </Border>
                                                <Border CornerRadius="6" Padding="8,3" Margin="6,0,0,0"
                                                        Background="#F0F8FF">
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="10" Foreground="#0077B6"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#03045E" TextWrapping="Wrap"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Org_Name}"
                                                       FontSize="11" Foreground="#0077B6"
                                                       Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11" Foreground="#5E7A8A"
                                                       TextWrapping="Wrap" MaxHeight="48"
                                                       Margin="0,0,0,10"/>
                                            <TextBlock Text="{Binding PostDateDisplay}"
                                                       FontSize="10" Foreground="#AAAAAA"
                                                       Margin="0,0,0,12"/>

                                            <!-- Donate to this need button -->
                                            <Button Command="{Binding DataContext.DonateToNeedCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Height="36" FontSize="12" FontWeight="SemiBold"
                                                    Foreground="White" BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="8"
                                                                Background="{TemplateBinding Background}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <Button.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                                        <GradientStop Color="#0077B6" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Button.Background>
                                                <TextBlock Text="🤲  Donate for This Need"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>