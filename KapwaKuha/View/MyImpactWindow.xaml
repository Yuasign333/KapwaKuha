<Window x:Class="KapwaKuha.View.MyImpactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — My Impact"
          Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="380" Height="380" Opacity="0.12"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="My Impact Dashboard" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                            Content="⟳ Refresh" Background="Transparent" BorderThickness="0"
                            Foreground="#CAF0F8" FontSize="12" Cursor="Hand" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <!-- Donor label -->
                    <Border Background="White" CornerRadius="14" Padding="20,16"
                            Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💙 " FontSize="22" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DonorName}" FontSize="16" FontWeight="Bold"
                                           Foreground="#03045E"/>
                                <TextBlock Text="Your community impact at a glance."
                                           FontSize="12" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Metric cards row -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,20">
                        <!-- Total Donated -->
                        <Border Background="White" CornerRadius="16" Padding="22,18" Margin="0,0,14,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.14"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🤲" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Total Donated" FontSize="12"
                                           Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TotalDonated}" FontSize="32"
                                           FontWeight="Bold" Foreground="#00B4D8"/>
                                <TextBlock Text="items posted" FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Claimed -->
                        <Border Background="White" CornerRadius="16" Padding="22,18" Margin="0,0,14,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.14"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="✅" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Successfully Claimed" FontSize="12"
                                           Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TotalClaimed}" FontSize="32"
                                           FontWeight="Bold" Foreground="#2DC653"/>
                                <TextBlock Text="items received" FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </Border>

                        <!-- Active Items -->
                        <Border Background="White" CornerRadius="16" Padding="22,18">
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.14"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="📦" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Still Available" FontSize="12"
                                           Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ActiveItems}" FontSize="32"
                                           FontWeight="Bold" Foreground="#0077B6"/>
                                <TextBlock Text="awaiting claim" FontSize="11" Foreground="#5E7A8A"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Avg + community message -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="22,18">
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.10"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="⏱" FontSize="28" Margin="0,0,0,8"/>
                                <TextBlock Text="Avg. Time to Claim" FontSize="12"
                                           Foreground="#5E7A8A" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding AvgStorageDisplay}" FontSize="18"
                                           FontWeight="Bold" Foreground="#03045E" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#EBF7FB" CornerRadius="16" Padding="22,18">
                            <Border.Effect>
                                <DropShadowEffect Color="#00B4D8" BlurRadius="14" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="💙 Kapwa Impact" FontSize="14"
                                           FontWeight="Bold" Foreground="#0077B6" Margin="0,0,0,8"/>
                                <TextBlock Text="Every item you donate is a connection. You're not just giving things — you're giving hope and dignity to your community."
                                           FontSize="12" Foreground="#5E7A8A" TextWrapping="Wrap"
                                           LineHeight="18"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>