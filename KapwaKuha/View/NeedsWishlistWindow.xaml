<Window x:Class="KapwaKuha.View.NeedsWishlistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KapwaKuha.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:NeedsWishlistDesignViewModel, IsDesignTimeCreatable=True}"
        Title="KapwaKuha — Needs Wishlist"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity="0.06" Width="1980"
               HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOPBAR -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Needs Wishlist" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.8*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT — FORM PANEL -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="32,24,16,24">
                    <StackPanel>

                        <!-- Error banner -->
                        <Border Background="#44FF4D4D" BorderBrush="#66FF0000" BorderThickness="1"
                                CornerRadius="10" Padding="12,10" Margin="0,0,0,16"
                                Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#B30000"
                                       FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <Border Background="#EEFFFFFF" BorderBrush="#88FFFFFF" BorderThickness="1.5"
                                CornerRadius="20" Padding="32">
                            <Border.Effect>
                                <DropShadowEffect Color="#0077B6" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>

                                <!-- Form header -->
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="20" FontWeight="Bold" Foreground="#0A2540" Margin="0,0,0,4">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="📝 Post a New Need"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Text" Value="✏️ Edit Your Post"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#5E7A8A">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Fill out the details of what your organization urgently needs."/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Text" Value="Changes will be sent to admin for re-approval before going live."/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding ClearSelectionCommand}"
                                            Height="34" Padding="16,0" FontSize="12" FontWeight="SemiBold"
                                            Foreground="#0077B6" BorderBrush="#0077B6" BorderThickness="1.5"
                                            Background="Transparent" Cursor="Hand"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="✕ Cancel Edit"/>
                                    </Button>
                                </Grid>

                                <!-- Locked-for-approved notice -->
                                <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,20"
                                        Background="#FEF9C3" BorderBrush="#FDE047" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPost.Admin_Approval_Status}" Value="Approved">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔒" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#854D0E" VerticalAlignment="Center">
                                            <Run FontWeight="Bold" Text="This post is currently live."/>
                                            <Run Text=" Editing a live post will send it back to admin for re-review before changes go public."/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Title -->
                                <TextBlock Text="Request Title" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#0A2540" Margin="4,0,0,8"/>
                                <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                        Padding="12,0" Background="White" Margin="0,0,0,20">
                                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Background="Transparent" BorderThickness="0"
                                             Foreground="#0A2540" FontSize="15" VerticalContentAlignment="Center"
                                             MaxLength="200" IsEnabled="{Binding CanEditSelected}"/>
                                </Border>

                                <!-- Description -->
                                <TextBlock Text="Description (What is needed and why?)" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#0A2540" Margin="4,0,0,8"/>
                                <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                                        Padding="12,12" Background="White" Margin="0,0,0,24">
                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                             Height="120" Background="Transparent" BorderThickness="0"
                                             Foreground="#0A2540" FontSize="14" TextWrapping="Wrap"
                                             AcceptsReturn="True" VerticalContentAlignment="Top"
                                             MaxLength="1000" IsEnabled="{Binding CanEditSelected}"/>
                                </Border>

                                <!-- Urgency note for editing -->
                                <Border CornerRadius="10" Padding="12,10" Margin="0,0,0,16"
                                        Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <TextBlock FontSize="12" Foreground="#1E40AF" TextWrapping="Wrap">
                                        <Run Text="ℹ️ "/>
                                        <Run FontWeight="SemiBold" Text="Note: "/>
                                        <Run Text="You may suggest an urgency level, but the final urgency is set by the admin when they review and approve your post."/>
                                    </TextBlock>
                                </Border>

                                <!-- Urgency selector -->
                                <TextBlock Text="Urgency Level (Suggestion)" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#0A2540" Margin="4,0,0,12"/>
                                <Border Background="#FAFDFF" BorderBrush="#CAF0F8" BorderThickness="1"
                                        CornerRadius="12" Padding="16" Margin="0,0,0,24">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <RadioButton Content="Low" GroupName="Urgency" IsChecked="{Binding IsLow}"
                                                     IsEnabled="{Binding CanEditSelected}"
                                                     Foreground="#185FA5" FontWeight="SemiBold" FontSize="14" Margin="0,0,40,0"/>
                                        <RadioButton Content="Medium" GroupName="Urgency" IsChecked="{Binding IsMedium}"
                                                     IsEnabled="{Binding CanEditSelected}"
                                                     Foreground="#B8860B" FontWeight="SemiBold" FontSize="14" Margin="0,0,40,0"/>
                                        <RadioButton Content="High" GroupName="Urgency" IsChecked="{Binding IsHigh}"
                                                     IsEnabled="{Binding CanEditSelected}"
                                                     Foreground="#C0304A" FontWeight="SemiBold" FontSize="14"/>
                                    </StackPanel>
                                </Border>

                                <!-- Submit / Update buttons -->
                                <Button Command="{Binding PostNeedCommand}" Height="54"
                                        FontSize="15" FontWeight="Bold" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="14" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00A8E8" Offset="0"/>
                                            <GradientStop Color="#0077B6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="📬  Submit Need for Review"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Text" Value="Submitting..."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>

                                <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding UpdateNeedCommand}" Height="50"
                                            FontSize="14" FontWeight="Bold" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            IsEnabled="{Binding CanEditSelected}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="12" Background="{TemplateBinding Background}" Opacity="{TemplateBinding Opacity}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#00A8E8" Offset="0"/>
                                                <GradientStop Color="#0077B6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Button.Background>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="📬 Re-submit for Approval"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                            <Setter Property="Text" Value="Saving..."/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                    <Button Grid.Column="2" Command="{Binding DeleteNeedCommand}" Height="50"
                                            FontSize="14" FontWeight="Bold" Foreground="#DC2626"
                                            BorderBrush="#DC2626" BorderThickness="1.5" Background="White"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="12" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="🗑️ Delete Post"/>
                                    </Button>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <!-- Tip card -->
                        <Border Background="#F9FDFF" BorderBrush="#BDE0FE" BorderThickness="1.5"
                                CornerRadius="16" Padding="20" Margin="0,20,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#0077B6" BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="💡" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="How approval works" FontSize="14" FontWeight="Bold"
                                               Foreground="#0077B6" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#5E7A8A" LineHeight="18">
                                    <Run Text="After you submit, an admin reviews your post and sets the final urgency level before it appears to donors. You'll see the status badge on your post list."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- RIGHT — IMAGE UPLOAD + MY POSTS LIST -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="16,24,32,24">
                    <StackPanel>

                        <!-- Image upload card -->
                        <Border Background="#EEFFFFFF" BorderBrush="#88FFFFFF" BorderThickness="1.5"
                                CornerRadius="20" Padding="28" Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect Color="#0077B6" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Attach a Photo (Optional)" FontSize="15" FontWeight="Bold"
                                           Foreground="#0A2540" Margin="0,0,0,16"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="10" BorderBrush="#6600B4D8"
                                            BorderThickness="1" Padding="12,0" Background="White">
                                        <TextBox Text="{Binding ImagePath}" Height="40" Background="Transparent"
                                                 BorderThickness="0" Foreground="#5E7A8A" FontSize="12"
                                                 IsReadOnly="True" VerticalContentAlignment="Center"/>
                                    </Border>
                                    <Button Grid.Column="2" Command="{Binding BrowseImageCommand}"
                                            Height="40" Padding="16,0" BorderThickness="0" Cursor="Hand"
                                            IsEnabled="{Binding CanEditSelected}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="10" Background="#0077B6" Opacity="{TemplateBinding Opacity}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="📷 Browse" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                    </Button>
                                </Grid>
                                <Border CornerRadius="12" Background="#FAFDFF" BorderBrush="#CAF0F8" BorderThickness="2"
                                        Padding="6" MinHeight="150" HorizontalAlignment="Stretch"
                                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                    <Border CornerRadius="8" ClipToBounds="True">
                                        <Image Source="{Binding ImagePath}" Stretch="Uniform" MaxHeight="220"/>
                                    </Border>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- My Posts list -->
                        <Border Background="#EEFFFFFF" BorderBrush="#88FFFFFF" BorderThickness="1.5"
        CornerRadius="20" Padding="24">
                            <Border.Effect>
                                <DropShadowEffect Color="#0077B6" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="✨ Daily Inspiration" FontSize="15" FontWeight="Bold"
                   Foreground="#0A2540" Margin="0,0,0,16"/>

                                <Border CornerRadius="14" BorderThickness="1" BorderBrush="#E5E7EB" Padding="20,24" Background="White">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                                        <TextBlock Text="“" FontSize="54" FontFamily="Georgia" FontWeight="Bold" 
                           Foreground="#0077B6" HorizontalAlignment="Center" Margin="0,-20,0,-25" Opacity="0.3"/>

                                        <TextBlock Text="We make a living by what we get, but we make a life by what we give." 
                           FontSize="15" FontWeight="SemiBold" FontStyle="Italic" Foreground="#0A2540" 
                           TextAlignment="Center" TextWrapping="Wrap" LineHeight="22" MaxWidth="320"/>

                                        <Border Height="1" Width="40" Background="#0077B6" Opacity="0.4" Margin="0,16,0,12" HorizontalAlignment="Center"/>

                                        <TextBlock Text="— Winston Churchill" FontSize="12" FontWeight="Bold" 
                           Foreground="#6B7280" HorizontalAlignment="Center"/>

                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>