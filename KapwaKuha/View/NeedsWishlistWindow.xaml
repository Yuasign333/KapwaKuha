<Window x:Class="KapwaKuha.View.NeedsWishlistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Needs Wishlist"
          Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Needs Wishlist" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <!-- Form card -->
                    <Border Background="White" CornerRadius="16" Padding="24" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="#00B4D8" BlurRadius="16" ShadowDepth="0" Opacity="0.12"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="📝 Post a Need Request" FontSize="15" FontWeight="Bold"
                                       Foreground="#03045E" Margin="0,0,0,4"/>
                            <TextBlock Text="Tell donors what your organization urgently needs."
                                       FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,16"/>

                            <!-- Error -->
                            <Border Background="#FFF0F5" CornerRadius="8" Padding="10,7" Margin="0,0,0,12"
                                    Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Title -->
                            <TextBlock Text="Request Title" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,6"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Padding="10,0" Background="#F0F8FB" Margin="0,0,0,12">
                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" Background="Transparent" BorderThickness="0"
                                         Foreground="#03045E" FontSize="13" VerticalContentAlignment="Center"
                                         MaxLength="200"/>
                            </Border>

                            <!-- Description -->
                            <TextBlock Text="Description  (what is needed and why)" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,6"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Padding="10,6" Background="#F0F8FB" Margin="0,0,0,12">
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Height="80" Background="Transparent" BorderThickness="0"
                                         Foreground="#03045E" FontSize="12" TextWrapping="Wrap"
                                         AcceptsReturn="True" VerticalContentAlignment="Top"
                                         MaxLength="1000"/>
                            </Border>

                            <!-- Urgency -->
                            <TextBlock Text="Urgency Level" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <RadioButton Content="Low" GroupName="Urgency"
                                             IsChecked="{Binding IsLow}"
                                             Foreground="#185FA5" FontSize="13" Margin="0,0,16,0"/>
                                <RadioButton Content="Medium" GroupName="Urgency"
                                             IsChecked="{Binding IsMedium}"
                                             Foreground="#B8860B" FontSize="13" Margin="0,0,16,0"/>
                                <RadioButton Content="High" GroupName="Urgency"
                                             IsChecked="{Binding IsHigh}"
                                             Foreground="#C0304A" FontSize="13"/>
                            </StackPanel>

                            <!-- Post button -->
                            <Button Command="{Binding PostNeedCommand}" Height="44"
                                    FontSize="13" FontWeight="Bold" Foreground="White"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.88"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                        <GradientStop Color="#0077B6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="📝  Post Need Request"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Text" Value="Posting..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Info card -->
                    <Border Background="#EBF7FB" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="💙 How It Reaches Donors" FontSize="13" FontWeight="Bold"
                                       Foreground="#0077B6" Margin="0,0,0,6"/>
                            <TextBlock Text="Your post will appear in the Donor's High-Priority Needs section, sorted by urgency. Donors can tap 'Donate for This Need' to post a matching item directly."
                                       FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>