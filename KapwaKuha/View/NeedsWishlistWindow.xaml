<Window x:Class="KapwaKuha.View.NeedsWishlistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Needs Wishlist"
          Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.06" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA  /  " FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="Needs Wishlist" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24">
        
        <Border Background="#AAFFFFFF" BorderBrush="#88FFFFFF" BorderThickness="1.5" 
                CornerRadius="20" Padding="28" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#0077B6" BlurRadius="24" ShadowDepth="4" Opacity="0.12"/>
            </Border.Effect>
            
            <StackPanel>
                <TextBlock Text="📝 Post a Need Request" FontSize="18" FontWeight="Bold"
                           Foreground="#0A2540" Margin="0,0,0,4"/>
                <TextBlock Text="Tell donors what your organization urgently needs."
                           FontSize="13" Foreground="#5E7A8A" Margin="0,0,0,20"/>

                <Border Background="#44FF4D4D" BorderBrush="#66FF0000" BorderThickness="1" 
                        CornerRadius="10" Padding="12,10" Margin="0,0,0,16"
                        Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#B30000" FontWeight="SemiBold"
                               FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Text="Request Title" FontSize="13" FontWeight="SemiBold"
                           Foreground="#0A2540" Margin="4,0,0,8"/>
                <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                        Padding="12,0" Background="White" Margin="0,0,0,16">
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Height="40" Background="Transparent" BorderThickness="0"
                             Foreground="#0A2540" FontSize="14" VerticalContentAlignment="Center"
                             MaxLength="200"/>
                </Border>

                <TextBlock Text="Description (what is needed and why)" FontSize="13"
                           FontWeight="SemiBold" Foreground="#0A2540" Margin="4,0,0,8"/>
                <Border CornerRadius="10" BorderBrush="#6600B4D8" BorderThickness="1"
                        Padding="12,8" Background="White" Margin="0,0,0,20">
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Height="90" Background="Transparent" BorderThickness="0"
                             Foreground="#0A2540" FontSize="13" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalContentAlignment="Top"
                             MaxLength="1000"/>
                </Border>

                <TextBlock Text="Urgency Level" FontSize="13" FontWeight="SemiBold"
                           Foreground="#0A2540" Margin="4,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="4,0,0,24">
                    <RadioButton Content="Low" GroupName="Urgency" IsChecked="{Binding IsLow}"
                                 Foreground="#185FA5" FontWeight="Medium" FontSize="14" Margin="0,0,20,0"/>
                    <RadioButton Content="Medium" GroupName="Urgency" IsChecked="{Binding IsMedium}"
                                 Foreground="#B8860B" FontWeight="Medium" FontSize="14" Margin="0,0,20,0"/>
                    <RadioButton Content="High" GroupName="Urgency" IsChecked="{Binding IsHigh}"
                                 Foreground="#C0304A" FontWeight="Medium" FontSize="14"/>
                </StackPanel>

                <Button Command="{Binding PostNeedCommand}" Height="48"
                        FontSize="14" FontWeight="Bold" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="12" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00A8E8" Offset="0"/>
                            <GradientStop Color="#0077B6" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="📝 Post Need Request"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Text" Value="Posting..."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </Border>

        <Border Background="#3300B4D8" BorderBrush="#44FFFFFF" BorderThickness="1.5" 
                CornerRadius="14" Padding="18">
            <StackPanel>
                <TextBlock Text="💙 How It Reaches Donors" FontSize="13" FontWeight="Bold"
                           Foreground="#0077B6" Margin="0,0,0,6"/>
                <TextBlock Text="Your post will appear in the Donor's High-Priority Needs section, sorted by urgency. Donors can tap 'Donate for This Need' to post a matching item directly."
                           FontSize="12" Foreground="#0A2540" TextWrapping="Wrap" LineHeight="18"/>
            </StackPanel>
        </Border>
        
    </StackPanel>
</ScrollViewer>
        </Grid>
    </Grid>
</Window>