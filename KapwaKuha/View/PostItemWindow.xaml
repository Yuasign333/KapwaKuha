<Window x:Class="KapwaKuha.View.PostItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Post Item"
        Height="620" Width="860"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- Background -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="380" Height="380" Opacity="0.12"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0077B6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding BackCommand}"
                            Content="← Back" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="13" Cursor="Hand" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="KAPWAKUHA" FontSize="12" FontWeight="Black"
                                   Foreground="#90E0EF" VerticalAlignment="Center"/>
                        <TextBlock Text="  /  Post Item" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding DonorLabel}"
                               Foreground="#CAF0F8" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Main content: two columns -->
            <Grid Grid.Row="1" Margin="24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Form -->
                <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="24">
                    <Border.Effect>
                        <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.12"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Post a Donation Item" FontSize="16" FontWeight="Bold"
                                       Foreground="#03045E" Margin="0,0,0,4"/>
                            <TextBlock Text="Choose how you'd like to donate."
                                       FontSize="11" Foreground="#5E7A8A" Margin="0,0,0,18"/>

                            <!-- Error -->
                            <Border Background="#FFF0F5" CornerRadius="8" Padding="10,7" Margin="0,0,0,12"
                                    Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Post type toggle -->
                            <TextBlock Text="Post Type" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border CornerRadius="8" Padding="14,9" Margin="0,0,10,0" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0F8FB"/>
                                            <Setter Property="BorderBrush" Value="#90E0EF"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeneralPost}" Value="True">
                                                    <Setter Property="Background" Value="#00B4D8"/>
                                                    <Setter Property="BorderBrush" Value="#00B4D8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SetGeneralPostCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🌐  " FontSize="13"/>
                                        <TextBlock Text="General Post" FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#0077B6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGeneralPost}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="8" Padding="14,9" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0F8FB"/>
                                            <Setter Property="BorderBrush" Value="#90E0EF"/>
                                            <Setter Property="BorderThickness" Value="1.5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDirectTarget}" Value="True">
                                                    <Setter Property="Background" Value="#0077B6"/>
                                                    <Setter Property="BorderBrush" Value="#0077B6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SetDirectTargetCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎯  " FontSize="13"/>
                                        <TextBlock Text="Direct Target" FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#0077B6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectTarget}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Item Name -->
                            <TextBlock Text="Item Name" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,6"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Padding="10,0" Background="#F0F8FB" Margin="0,0,0,14">
                                <TextBox Text="{Binding ItemName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="36" Background="Transparent" BorderThickness="0"
                                         Foreground="#03045E" FontSize="13" VerticalContentAlignment="Center"
                                         MaxLength="100"/>
                            </Border>

                            <!-- Category + Condition row -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Category" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#03045E" Margin="0,0,0,6"/>
                                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                            Background="#F0F8FB">
                                        <ComboBox ItemsSource="{Binding Categories}"
                                                  SelectedItem="{Binding SelectedCategory}"
                                                  Height="36" Background="Transparent" BorderThickness="0"
                                                  Foreground="#03045E" FontSize="12" Padding="10,0"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Condition" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#03045E" Margin="0,0,0,6"/>
                                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                            Background="#F0F8FB">
                                        <ComboBox ItemsSource="{Binding Conditions}"
                                                  SelectedItem="{Binding SelectedCondition}"
                                                  Height="36" Background="Transparent" BorderThickness="0"
                                                  Foreground="#03045E" FontSize="12" Padding="10,0"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Beneficiary ComboBox (Direct Target only) -->
                            <StackPanel Margin="0,0,0,14"
                                        Visibility="{Binding IsDirectTarget, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Target Beneficiary" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,6"/>
                                <Border CornerRadius="9" BorderBrush="#0077B6" BorderThickness="1.5"
                                        Background="#EBF7FB">
                                    <ComboBox ItemsSource="{Binding Beneficiaries}"
                                              SelectedItem="{Binding SelectedBeneficiary}"
                                              DisplayMemberPath="DisplayName"
                                              Height="36" Background="Transparent" BorderThickness="0"
                                              Foreground="#03045E" FontSize="12" Padding="10,0"/>
                                </Border>
                            </StackPanel>

                            <!-- Post button -->
                            <Button Command="{Binding SaveCommand}" Height="44"
                                    FontSize="14" FontWeight="Bold" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Margin="0,6,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.88"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#CCCCCC"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00B4D8" Offset="0"/>
                                        <GradientStop Color="#0077B6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="🤲  Post Item"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                    <Setter Property="Text" Value="Posting..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Right: Info panel -->
                <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#00B4D8" BlurRadius="18" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📘 How It Works" FontSize="13" FontWeight="Bold"
                                   Foreground="#03045E" Margin="0,0,0,14"/>

                        <Border Background="#EBF7FB" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="🌐  General Post" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#0077B6" Margin="0,0,0,4"/>
                                <TextBlock Text="Your item goes to the public marketplace. Any beneficiary can browse and claim it."
                                           FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F0F8FF" CornerRadius="10" Padding="14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="🎯  Direct Target" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#03045E" Margin="0,0,0,4"/>
                                <TextBlock Text="Select a specific beneficiary. The item goes straight to their Claim Tracker."
                                           FontSize="11" Foreground="#5E7A8A" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F0FFF4" CornerRadius="10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="💙 Kapwa Spirit" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#2E7D52" Margin="0,0,0,4"/>
                                <TextBlock Text="Every item you post is a connection. Donate is something they await."
                                           FontSize="11" Foreground="#388E3C" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>