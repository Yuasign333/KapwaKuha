<Window x:Class="KapwaKuha.View.SignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Create Account"
        Height="700" Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">

    <Grid>
        <!-- Background -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CAF0F8" Offset="0"/>
                    <GradientStop Color="#ADE8F4" Offset="0.5"/>
                    <GradientStop Color="#90E0EF" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Ellipse Width="380" Height="380" Opacity="0.13"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="280" Height="280" Opacity="0.10"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-60,0,0,-60">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0077B6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border HorizontalAlignment="Center" VerticalAlignment="Top"
                    Width="560" Margin="0,32,0,32" CornerRadius="22" Padding="36,30">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFFEE" Offset="0"/>
                        <GradientStop Color="#EBF7FBDD" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#00B4D8" BlurRadius="36" ShadowDepth="0" Opacity="0.18"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Back -->
                    <Button Command="{Binding BackCommand}" HorizontalAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#0077B6" FontSize="12" Cursor="Hand"
                            Margin="0,0,0,14">
                        <TextBlock Text="← Back to Login" TextDecorations="Underline"/>
                    </Button>

                    <!-- Header -->
                    <TextBlock Text="{Binding RoleLabel}" FontSize="22" FontWeight="Bold"
                               Foreground="#03045E" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Fill in all fields to register your account."
                               FontSize="12" Foreground="#5E7A8A"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- Error banner -->
                    <Border Background="#FFF0F5" CornerRadius="8" Padding="12,8" Margin="0,0,0,14"
                            Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Row: First + Last Name -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Padding="10,0" Background="#F0F8FB">
                                <TextBox Text="{Binding FName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" Background="Transparent" BorderThickness="0"
                                         Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last Name" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Padding="10,0" Background="#F0F8FB">
                                <TextBox Text="{Binding LName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" Background="Transparent" BorderThickness="0"
                                         Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Username (Donor only) -->
                    <StackPanel Margin="0,0,0,12"
                                Visibility="{Binding IsDonor, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Username" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#03045E" Margin="0,0,0,5"/>
                        <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                Padding="10,0" Background="#F0F8FB">
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34" Background="Transparent" BorderThickness="0"
                                     Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Sex + Org (Beneficiary only) -->
                    <Grid Margin="0,0,0,12"
                          Visibility="{Binding IsBeneficiary, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sex" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Background="#F0F8FB">
                                <ComboBox SelectedValue="{Binding Sex}"
                                          Height="34" Background="Transparent" BorderThickness="0"
                                          Foreground="#03045E" FontSize="12" Padding="10,0">
                                    <ComboBoxItem Content="Male" IsSelected="True"/>
                                    <ComboBoxItem Content="Female"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Organization" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Background="#F0F8FB">
                                <ComboBox ItemsSource="{Binding Organizations}"
                                          Height="34" Background="Transparent" BorderThickness="0"
                                          Foreground="#03045E" FontSize="12" Padding="10,0"
                                          x:Name="OrgCombo">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Item2}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Contact -->
                    <TextBlock Text="Contact Number  (09XXXXXXXXX)" FontSize="11" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                            Padding="10,0" Background="#F0F8FB" Margin="0,0,0,12">
                        <TextBox Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Background="Transparent" BorderThickness="0"
                                 Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Password row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Password  (min 6)" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Padding="10,0" Background="#F0F8FB">
                                <PasswordBox x:Name="PwBox" Height="34" Background="Transparent"
                                             BorderThickness="0" Foreground="#03045E"
                                             FontSize="12" Padding="0,8,0,0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Confirm Password" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                                    Padding="10,0" Background="#F0F8FB">
                                <PasswordBox x:Name="ConfirmPwBox" Height="34" Background="Transparent"
                                             BorderThickness="0" Foreground="#03045E"
                                             FontSize="12" Padding="0,8,0,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Security question -->
                    <TextBlock Text="Security Question" FontSize="11" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                            Background="#F0F8FB" Margin="0,0,0,10">
                        <ComboBox SelectedValue="{Binding SecurityQuestion}"
                                  SelectedValuePath="Content"
                                  Height="34" Background="Transparent" BorderThickness="0"
                                  Foreground="#03045E" FontSize="12" Padding="10,0">
                            <ComboBoxItem Content="What is your pet name?" IsSelected="True"/>
                            <ComboBoxItem Content="What is your mother's maiden name?"/>
                            <ComboBoxItem Content="What is your childhood nickname?"/>
                            <ComboBoxItem Content="What city were you born in?"/>
                        </ComboBox>
                    </Border>

                    <TextBlock Text="Security Answer" FontSize="11" FontWeight="SemiBold"
                               Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border CornerRadius="9" BorderBrush="#90E0EF" BorderThickness="1.5"
                            Padding="10,0" Background="#F0F8FB" Margin="0,0,0,20">
                        <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Background="Transparent" BorderThickness="0"
                                 Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Register button -->
                    <Button x:Name="RegisterBtn" Height="44" FontSize="14" FontWeight="Bold"
                            Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="RegisterBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00B4D8" Offset="0"/>
                                <GradientStop Color="#0077B6" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Create Account →"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Text" Value="Creating account..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>