<Window x:Class="KapwaKuha.View.SignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KapwaKuha — Create Account"
         Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">

    <Grid>



        <!-- Background -->
        <Rectangle>
            
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="White" Offset="0"/>
      
                    <GradientStop Color="LightSkyBlue" Offset="1"/>
                </LinearGradientBrush>
                
            </Rectangle.Fill>
        </Rectangle>

        <Image Source="https://i.imgur.com/y4MrK4c.jpeg" Opacity ="0.10" Width="1980" HorizontalAlignment="Center" VerticalAlignment="Center" Height="2808" RenderTransformOrigin="0.5,0.5" />



        <Ellipse Width="380" Height="380" Opacity="0.13"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-100,-80,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="280" Height="280" Opacity="0.10"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-60,0,0,-60">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#0077B6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Width="560" Margin="0,32,0,32" CornerRadius="22" Padding="36,30"
        BorderThickness="1.5">

                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="#33FFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                        <GradientStop Color="#66FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Border.Effect>
                    <DropShadowEffect Color="#0077B6" BlurRadius="40" ShadowDepth="2" Opacity="0.2"/>
                </Border.Effect>

                <StackPanel>
                    <Button Command="{Binding BackCommand}" HorizontalAlignment="Left"
                Background="Transparent" BorderThickness="0"
                Foreground="#0077B6" FontSize="12" Cursor="Hand"
                Margin="0,0,0,14">
                        <TextBlock Text="← Back to Login" TextDecorations="Underline"/>
                    </Button>

                    <TextBlock Text="{Binding RoleLabel}" FontSize="24" FontWeight="Bold"
                   Foreground="#03045E" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Fill in all fields to register your account."
                   FontSize="12" Foreground="#5E7A8A"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <Border Background="#4DFFF0F5" CornerRadius="8" Padding="12,8" Margin="0,0,0,14"
                Visibility="{Binding ErrorVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0304A"
                       FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Padding="10,0" Background="#4DFFFFFF">
                                <TextBox Text="{Binding FName, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Background="Transparent" BorderThickness="0"
                             Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last Name" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Padding="10,0" Background="#4DFFFFFF">
                                <TextBox Text="{Binding LName, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" Background="Transparent" BorderThickness="0"
                             Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12" Visibility="{Binding IsDonor, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Username" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                        <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Padding="10,0" Background="#4DFFFFFF">
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="34" Background="Transparent" BorderThickness="0"
                         Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <Grid Margin="0,0,0,12" Visibility="{Binding IsBeneficiary, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sex" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Background="#4DFFFFFF">
                                <ComboBox SelectedValue="{Binding Sex}" Height="34" Background="Transparent" BorderThickness="0" Foreground="#03045E" FontSize="12" Padding="10,0">
                                    <ComboBoxItem Content="Male" IsSelected="True"/>
                                    <ComboBoxItem Content="Female"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Organization" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Background="#4DFFFFFF">
                                <ComboBox ItemsSource="{Binding Organizations}" Height="34" Background="Transparent" BorderThickness="0" Foreground="#03045E" FontSize="12" Padding="10,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Item2}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Contact Number" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Padding="10,0" Background="#4DFFFFFF" Margin="0,0,0,12">
                        <TextBox Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}"
                     Height="34" Background="Transparent" BorderThickness="0"
                     Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                    </Border>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Password" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Padding="10,0" Background="#4DFFFFFF">
                                <PasswordBox x:Name="PwBox" Height="34" Background="Transparent" BorderThickness="0" Foreground="#03045E" FontSize="12" Padding="0,8,0,0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Confirm Password" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                            <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Padding="10,0" Background="#4DFFFFFF">
                                <PasswordBox x:Name="ConfirmPwBox" Height="34" Background="Transparent" BorderThickness="0" Foreground="#03045E" FontSize="12" Padding="0,8,0,0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Security Question" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Background="#4DFFFFFF" Margin="0,0,0,10">
                        <ComboBox SelectedValue="{Binding SecurityQuestion}" SelectedValuePath="Content" Height="34" Background="Transparent" BorderThickness="0" Foreground="#03045E" FontSize="12" Padding="10,0">
                            <ComboBoxItem Content="What is your pet name?" IsSelected="True"/>
                            <ComboBoxItem Content="What city were you born in?"/>
                        </ComboBox>
                    </Border>

                    <TextBlock Text="Security Answer" FontSize="11" FontWeight="SemiBold" Foreground="#03045E" Margin="0,0,0,5"/>
                    <Border CornerRadius="9" BorderBrush="#B390E0EF" BorderThickness="1.2" Padding="10,0" Background="#4DFFFFFF" Margin="0,0,0,24">
                        <TextBox Text="{Binding SecurityAnswer, UpdateSourceTrigger=PropertyChanged}"
                     Height="34" Background="Transparent" BorderThickness="0"
                     Foreground="#03045E" FontSize="12" VerticalContentAlignment="Center"/>
                    </Border>

                    <Button x:Name="RegisterBtn" Height="46" FontSize="14" FontWeight="Bold" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RegisterBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00B4D8" Offset="0"/>
                                <GradientStop Color="#0077B6" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <TextBlock Text="Create Account →" />
                    </Button>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>